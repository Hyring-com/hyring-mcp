{
  "name": "hyring-mcp",
  "version": "1.0.0",
  "description": "MCP servers for Hyring AI Screener — full suite + per-interview-type products + results-only product",
  "main": "dist/bin/full.js",
  "bin": {
    "hyring-mcp": "dist/bin/full.js",
    "hyring-mcp-fixed": "dist/bin/fixed.js",
    "hyring-mcp-dynamic": "dist/bin/dynamic.js",
    "hyring-mcp-coding": "dist/bin/coding.js",
    "hyring-mcp-verbal": "dist/bin/verbal.js",
    "hyring-mcp-results": "dist/bin/results.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/bin/full.js",
    "start:fixed": "node dist/bin/fixed.js",
    "start:dynamic": "node dist/bin/dynamic.js",
    "start:coding": "node dist/bin/coding.js",
    "start:verbal": "node dist/bin/verbal.js",
    "start:results": "node dist/bin/results.js",
    "dev": "ts-node src/bin/full.ts",
    "dev:fixed": "ts-node src/bin/fixed.ts",
    "dev:dynamic": "ts-node src/bin/dynamic.ts",
    "dev:coding": "ts-node src/bin/coding.ts",
    "dev:verbal": "ts-node src/bin/verbal.ts",
    "dev:results": "ts-node src/bin/results.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "axios": "^1.7.2",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
